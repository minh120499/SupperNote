{
  "extends": [
    "react-app"
  ],
  "plugins": [
    "react",
    "typescript"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": "warn",
    "eqeqeq": "error",
    "import/no-anonymous-default-export": [
      "error",
      {
        "allowArrowFunction": true,
        "allowAnonymousFunction": true
      }
    ],
    "react-hooks/exhaustive-deps": "warn",
    "no-console": "warn"
  }
}